{
  "manifest_version": 3,
  "name": "Идеограф — Навигатор по идеям книг",
  "description": "Извлечение, структурирование и навигация по идеям из учебников и научных книг",
  "version": "0.3.0",
  "permissions": [
    "storage",
    "activeTab",
    "nativeMessaging"
  ],
  "action": {
    "default_title": "Идеограф",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
