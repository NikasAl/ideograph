{
  "manifest_version": 3,
  "name": "Идеограф — Навигатор по идеям книг",
  "description": "Извлечение, структурирование и навигация по идеям из учебников и научных книг",
  "version": "0.4.0",
  "permissions": [
    "storage",
    "activeTab",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Идеограф",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+I",
        "mac": "Alt+I"
      },
      "description": "Открыть Идеограф"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
